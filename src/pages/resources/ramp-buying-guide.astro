---
import Layout from '../../layouts/Layout.astro';

const title = 'Ramp Buying Guide for NY Homes | Portable vs Permanent Ramps';
const description = 'How to choose the right ramp for your Rochester, Buffalo or Syracuse home. Portable, modular, and permanent options explained with local considerations.';
---

<Layout title={title} description={description}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-4xl font-bold tracking-tight mb-4">Ramp Buying Guide for Upstate New York Homes</h1>

    <div class="prose prose-slate">
      <h2>Types of Ramps We Install</h2>
      <ul>
        <li><strong>Portable/Folding Ramps:</strong> Best for temporary use or rentals. Easy to store and move. Great for Rochester apartments or short-term needs.</li>
        <li><strong>Modular Aluminum Ramps:</strong> Quick to install, adjustable, and removable. Popular in Buffalo for homes with changing needs.</li>
        <li><strong>Permanent Wooden or Concrete Ramps:</strong> Most durable and code-compliant for long-term use in Syracuse and surrounding areas.</li>
      </ul>

      <h2>Local Considerations</h2>
      <p>Upstate New York weather means ramps need good traction (we recommend non-slip surfaces) and proper drainage. Many older homes have limited space, so custom designs are common.</p>

      <h2>ADA Guidelines &amp; Local Codes</h2>
      <p>For residential use, we follow best practices for slope (1:12 ratio ideal) and width. Commercial or public buildings have stricter requirements.</p>

      <a href="/contact" class="not-prose inline-block mt-6 bg-sky-600 text-white px-6 py-3 rounded-xl">Get a Free Ramp Assessment →</a>
    </div>
  </div>
</Layout>
