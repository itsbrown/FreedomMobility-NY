---
import Layout from '../layouts/Layout.astro';

const title = 'Our Brands & Partners | Freedom Mobility NY';
const description = 'We partner with leading manufacturers including AmeriGlide, Stannah, Harmar, Bruno, Acorn, Handicare, Savaria and Garaventa to deliver top-quality stairlifts, ramps and lifts across Rochester, Buffalo and Syracuse NY.';

const brands = [
  {
    name: 'AmeriGlide',
    url: 'https://ameriglide.com/',
    desc: 'Affordable, reliable stairlifts and vertical platform lifts designed for easy home installation and everyday use.'
  },
  {
    name: 'Stannah',
    url: 'https://www.stannah.com/stairlifts/',
    desc: 'World-renowned British stairlifts known for exceptional quality, safety features, and elegant design that blends with any home.'
  },
  {
    name: 'Harmar',
    url: 'https://www.harmar.com/',
    desc: 'Innovative vehicle lifts, stairlifts, and vertical platform lifts trusted for durability and smooth performance.'
  },
  {
    name: 'Bruno',
    url: 'https://www.bruno.com/',
    desc: 'Premium American-made stairlifts and outdoor lifts built for reliability and backed by strong warranties.'
  },
  {
    name: 'Acorn',
    url: 'https://www.acornstairlifts.com/',
    desc: 'One of the world’s largest stairlift manufacturers, offering straight and curved models with excellent value and service.'
  },
  {
    name: 'Handicare',
    url: 'https://www.handicare.com/',
    desc: 'Comprehensive accessibility solutions including stairlifts, ramps, and transfer aids focused on independence and safety.'
  },
  {
    name: 'Savaria',
    url: 'https://www.savaria.com/',
    desc: 'High-quality residential elevators, stairlifts, and vertical platform lifts with a reputation for innovation and customization.'
  },
  {
    name: 'Garaventa',
    url: 'https://www.garaventa.com/',
    desc: 'Specialized lifting and accessibility equipment, including platform lifts and stair climbers engineered for demanding installations.'
  }
];
---

<Layout title={title} description={description}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <div class="max-w-3xl mb-10">
      <span class="uppercase tracking-[2px] text-sky-600 text-sm font-semibold">Trusted Manufacturers</span>
      <h1 class="text-4xl md:text-5xl font-bold tracking-tighter mt-3 mb-4">Our Brands &amp; Partners</h1>
      <p class="text-xl text-slate-600">
        Freedom Mobility NY is proud to partner with the industry’s most respected manufacturers. 
        Every product we install and service is chosen for its quality, reliability, and suitability for homes throughout Western and Central New York.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {brands.map(brand => (
        <div class="group flex flex-col bg-white border border-slate-200 rounded-2xl p-6 hover:border-sky-200 hover:shadow-sm transition-all">
          <h2 class="text-2xl font-semibold mb-3 group-hover:text-sky-600 transition-colors">{brand.name}</h2>
          <p class="text-slate-600 flex-1 mb-5">{brand.desc}</p>
          <a 
            href={brand.url} 
            target="_blank" 
            rel="noopener" 
            class="inline-flex items-center text-sm font-medium text-sky-600 hover:text-sky-700 group-hover:underline"
          >
            Visit {brand.name} website →
          </a>
        </div>
      ))}
    </div>

    <div class="mt-12 bg-slate-50 rounded-3xl p-8 md:p-10 text-center">
      <h2 class="text-2xl font-semibold tracking-tight mb-3">All Backed by Local Expertise</h2>
      <p class="max-w-2xl mx-auto text-slate-600 mb-6">
        No matter which brand you choose, our Rochester-based team handles professional installation, ongoing maintenance, and repairs for every product we carry across Rochester, Buffalo, Syracuse, and surrounding communities.
      </p>
      <a href="/contact" class="inline-flex items-center bg-slate-900 hover:bg-black text-white px-8 py-3.5 rounded-xl font-semibold transition">
        Schedule a Free Consultation
      </a>
    </div>

    <div class="mt-8 text-center">
      <p class="text-sm text-slate-600">Learn more in our <a href="/resources" class="underline">free guides and resources</a>, including cost breakdowns and buying advice for each product category. Read real stories from clients like you on our <a href="/testimonials" class="underline">testimonials page</a>.</p>
    </div>
  </div>
</Layout>
