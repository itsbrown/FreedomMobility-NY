---
import Layout from '../../layouts/Layout.astro';
import { getLocationBySlug, getAllLocationSlugs, type Location } from '../../data/locations';

export async function getStaticPaths() {
  const slugs = getAllLocationSlugs();
  return slugs.map((slug) => ({
    params: { slug },
    props: { location: getLocationBySlug(slug)! },
  }));
}

interface Props {
  location: Location;
}

const { location } = Astro.props;

const title = location.metaTitle || `${location.name} Home Accessibility | Stairlifts, Ramps & Lifts`;
const description = location.metaDescription || `Expert stairlifts, ramps, vertical platform lifts and home modifications in ${location.fullName}. Free in-home consultations from Freedom Mobility NY.`;

const services = [
  { name: 'Stairlifts', href: '/stairlifts', desc: 'Straight and curved stairlifts for indoor and outdoor use.' },
  { name: 'Ramps', href: '/ramps', desc: 'Portable and permanent access ramps tailored to your home.' },
  { name: 'Vertical Platform Lifts', href: '/vertical-platform-lifts', desc: 'Wheelchair and power chair access to porches, decks and raised areas.' },
  { name: 'Service & Repair', href: '/service', desc: 'Maintenance and repairs for all major brands of mobility equipment.' },
];
---

<Layout title={title} description={description}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <!-- Breadcrumb -->
    <nav class="text-sm mb-8 text-slate-500">
      <a href="/" class="hover:text-slate-700">Home</a>
      <span class="mx-1">/</span>
      <a href="/locations" class="hover:text-slate-700">Locations</a>
      <span class="mx-1">/</span>
      <span class="text-slate-700">{location.fullName}</span>
    </nav>

    <div class="max-w-3xl mb-10">
      <span class="text-sky-600 font-semibold tracking-wider text-sm">SERVING {location.fullName.toUpperCase()}</span>
      <h1 class="text-4xl md:text-5xl font-bold tracking-tighter mt-3 mb-4">
        Home Accessibility Experts in {location.fullName}
      </h1>
      <p class="text-xl text-slate-600">
        {location.description}
      </p>
    </div>

    <div class="flex flex-wrap gap-4 mb-12">
      <a href="/contact" class="inline-flex items-center bg-slate-900 hover:bg-black text-white px-8 py-3.5 rounded-xl font-semibold transition">
        Schedule Free Consultation in {location.name}
      </a>
      <a href="tel:5854880771" class="inline-flex items-center border border-slate-300 hover:bg-slate-50 px-8 py-3.5 rounded-xl font-semibold transition">
        Call (585) 488-0771
      </a>
    </div>

    <!-- Services available -->
    <div class="mb-16">
      <h2 class="text-2xl font-semibold tracking-tight mb-6">Services Available in {location.name}</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {services.map((service) => (
          <a href={service.href} class="group block border border-slate-200 rounded-2xl p-6 hover:border-sky-200 hover:shadow-sm transition">
            <h3 class="font-semibold text-xl mb-2 group-hover:text-sky-600">{service.name}</h3>
            <p class="text-slate-600 mb-4">{service.desc}</p>
            <span class="text-sm font-medium text-sky-600">Learn more about {service.name.toLowerCase()} in {location.name} →</span>
          </a>
        ))}
      </div>
    </div>

    <!-- Why choose us in this area -->
    <div class="bg-slate-50 rounded-3xl p-8 md:p-10 mb-12">
      <h2 class="text-2xl font-semibold tracking-tight mb-6">Why Homeowners in {location.name} Choose Freedom Mobility NY</h2>
      <div class="grid md:grid-cols-3 gap-8 text-sm">
        <div>
          <div class="font-semibold mb-1">Free In-Home Consultations</div>
          <p class="text-slate-600">Our team visits your home in {location.name} to assess needs, take measurements, and recommend the best solutions — at no cost.</p>
        </div>
        <div>
          <div class="font-semibold mb-1">Local Expertise</div>
          <p class="text-slate-600">We understand the homes and accessibility challenges specific to the {location.name} area, from older housing stock to new construction.</p>
        </div>
        <div>
          <div class="font-semibold mb-1">Professional Installation &amp; Support</div>
          <p class="text-slate-600">Fully trained technicians handle installation and provide ongoing service and repairs for all equipment we provide in {location.name}.</p>
        </div>
      </div>
    </div>

    <div class="text-center">
      <p class="text-lg mb-4">Ready to regain your independence in {location.fullName}?</p>
      <a href="/contact" class="inline-flex items-center bg-sky-600 hover:bg-sky-700 text-white px-8 py-3.5 rounded-xl font-semibold">
        Book Your Free Consultation Today
      </a>
    </div>
  </div>
</Layout>
