---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

---

<Layout 
  title="Vertical Platform Lifts Rochester NY | Wheelchair Lifts Buffalo Syracuse"
  description="Vertical platform lifts for wheelchair and power chair access in Rochester, Buffalo and Syracuse NY homes. Free consultations and professional installation."
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <nav class="text-sm mb-6 text-slate-500">
      <a href="/" class="hover:text-slate-700">Home</a> <span class="mx-1">/</span> 
      <span class="text-slate-700">Vertical Platform Lifts</span>
    </nav>

    <div class="grid lg:grid-cols-12 gap-x-12 gap-y-10">
      <div class="lg:col-span-7">
        <span class="text-sky-600 font-semibold tracking-wider text-sm">FOR WHEELCHAIRS &amp; POWER CHAIRS</span>
        <h1 class="text-4xl md:text-5xl font-bold tracking-tighter mt-3 mb-6">Vertical Platform Lifts</h1>

        <div class="prose prose-lg text-slate-700">
          <p>
            Our vertical platform lifts cater to the needs of individuals using wheelchairs and power chairs, granting them access to raised porches, decks, and other elevated areas in both residential and commercial settings.
          </p>
          <p>
            Designed for safety and reliability, our lifts are easy to operate and built to withstand the elements. These mobility solutions, resembling small elevators, smoothly transport users vertically.
          </p>
        </div>

        <div class="mt-8 flex gap-4">
          <a href="/contact" class="bg-slate-900 text-white px-7 py-3 rounded-xl font-semibold">Get a Free Quote</a>
          <a href="/service" class="text-sm self-center underline">We also service existing lifts →</a>
        </div>
      </div>

      <div class="lg:col-span-5">
        <Image src="/images/VPL-001.jpg" alt="Vertical platform lift for wheelchair and power chair access" class="rounded-2xl w-full border" width="1024" height="819" loading="lazy" decoding="async" />
      </div>
    </div>
  </div>

  <div class="bg-slate-900 text-white py-12">
    <div class="max-w-5xl mx-auto px-4 grid md:grid-cols-3 gap-8 text-sm">
      <div>
        <div class="uppercase tracking-widest text-xs text-sky-400 mb-2">Ideal for</div>
        <ul class="space-y-1 text-slate-300">
          <li>Front &amp; rear porches</li>
          <li>Decks &amp; patios</li>
          <li>Garage entries</li>
          <li>Small commercial buildings</li>
        </ul>
      </div>
      <div>
        <div class="uppercase tracking-widest text-xs text-sky-400 mb-2">Features</div>
        <ul class="space-y-1 text-slate-300">
          <li>Weather-resistant construction</li>
          <li>Easy-to-use controls</li>
          <li>Non-skid platform surface</li>
          <li>Safety gate &amp; interlocks</li>
        </ul>
      </div>
      <div>
        <div class="uppercase tracking-widest text-xs text-sky-400 mb-2">Next step</div>
        <p class="text-slate-300">Schedule a free site evaluation. We'll assess your space and recommend the right model and lift capacity.</p>
        <a href="/contact" class="mt-3 inline-block text-white underline">Book your consultation →</a>
      </div>
    </div>
  </div>

  <!-- Internal Linking: Locations for this service -->
  <section class="max-w-5xl mx-auto px-4 py-12 border-t">
    <h2 class="text-xl font-semibold mb-4">Vertical Platform Lifts Available in These Areas</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-sm">
      <a href="/locations/rochester/vertical-platform-lifts" class="p-4 border rounded hover:bg-slate-50">Vertical Lifts in Rochester, NY →</a>
      <a href="/locations/buffalo/vertical-platform-lifts" class="p-4 border rounded hover:bg-slate-50">Vertical Lifts in Buffalo, NY →</a>
      <a href="/locations/syracuse/vertical-platform-lifts" class="p-4 border rounded hover:bg-slate-50">Vertical Lifts in Syracuse, NY →</a>
    </div>
    <p class="mt-3 text-xs text-slate-500">We also serve surrounding communities. <a href="/locations" class="underline">View all locations</a>.</p>
  </section>

  <!-- FAQ for Featured Snippets -->
  <section class="max-w-5xl mx-auto px-4 py-12">
    <h2 class="text-2xl font-semibold tracking-tight mb-6">Frequently Asked Questions About Vertical Platform Lifts</h2>
    <div class="space-y-4">
      <details class="border border-slate-200 rounded-xl p-4">
        <summary class="font-medium cursor-pointer">How much does a vertical platform lift cost in Rochester, Buffalo or Syracuse?</summary>
        <p class="mt-2 text-slate-600">VPL pricing depends on lift height, capacity, and whether it's indoor or outdoor. Most residential units range from $8,000 to $15,000 installed. We offer free site evaluations.</p>
      </details>
      <details class="border border-slate-200 rounded-xl p-4">
        <summary class="font-medium cursor-pointer">Can vertical lifts be used outdoors in New York winters?</summary>
        <p class="mt-2 text-slate-600">Yes. Our outdoor vertical platform lifts are weather-resistant and built to handle snow, ice and temperature swings common in Rochester, Buffalo and Syracuse.</p>
      </details>
      <details class="border border-slate-200 rounded-xl p-4">
        <summary class="font-medium cursor-pointer">Are vertical platform lifts safe for wheelchair users?</summary>
        <p class="mt-2 text-slate-600">Absolutely. All our VPLs include safety gates, non-skid platforms, emergency stops and meet applicable safety standards for reliable wheelchair and power chair access.</p>
      </details>
    </div>
  </section>

  <!-- FAQ Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How much does a vertical platform lift cost in Rochester, Buffalo or Syracuse?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "VPL pricing depends on lift height, capacity, and whether it's indoor or outdoor. Most residential units range from $8,000 to $15,000 installed. We offer free site evaluations."
        }
      },
      {
        "@type": "Question",
        "name": "Can vertical lifts be used outdoors in New York winters?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Our outdoor vertical platform lifts are weather-resistant and built to handle snow, ice and temperature swings common in Rochester, Buffalo and Syracuse."
        }
      },
      {
        "@type": "Question",
        "name": "Are vertical platform lifts safe for wheelchair users?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Absolutely. All our VPLs include safety gates, non-skid platforms, emergency stops and meet applicable safety standards for reliable wheelchair and power chair access."
        }
      }
    ]
  })} />
</Layout>
