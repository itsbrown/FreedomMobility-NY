---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Thank You | Freedom Mobility NY"
  description="Your consultation request has been received. A member of the Freedom Mobility NY team will contact you shortly."
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24 text-center">
    <div class="mx-auto mb-8 flex h-16 w-16 items-center justify-center rounded-full bg-emerald-100">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
      </svg>
    </div>

    <h1 class="text-4xl font-bold tracking-tight mb-4">Thank you!</h1>
    
    <p class="text-xl text-slate-600 mb-8">
      Your consultation request has been received. A member of the Freedom Mobility NY team will contact you shortly to confirm your free in-home visit.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/" class="inline-flex items-center justify-center bg-slate-900 hover:bg-black text-white px-8 py-3 rounded-xl font-semibold transition">
        Back to Home
      </a>
      <a href="tel:5854880771" class="inline-flex items-center justify-center border border-slate-300 hover:bg-slate-50 px-8 py-3 rounded-xl font-semibold transition">
        Call Us Now: (585) 488-0771
      </a>
    </div>

    <div class="mt-12 text-sm text-slate-500">
      <p>Need immediate help? Call us anytime during business hours.</p>
      <p class="mt-1">Rochester, NY • Serving Buffalo &amp; Syracuse areas</p>
    </div>
  </div>
</Layout>
