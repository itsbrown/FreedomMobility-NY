---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import vplImg from '../assets/HA_SL300_Lifestyle-UpStairs.png';
---

<Layout 
  title="Vertical Platform Lifts | Freedom Mobility NY"
  description="Vertical platform lifts (VPL) for wheelchair and power chair access to porches, decks and raised areas. Professional installation in Rochester, Buffalo & Syracuse NY."
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <nav class="text-sm mb-6 text-slate-500">
      <a href="/" class="hover:text-slate-700">Home</a> <span class="mx-1">/</span> 
      <span class="text-slate-700">Vertical Platform Lifts</span>
    </nav>

    <div class="grid lg:grid-cols-12 gap-x-12 gap-y-10">
      <div class="lg:col-span-7">
        <span class="text-sky-600 font-semibold tracking-wider text-sm">FOR WHEELCHAIRS &amp; POWER CHAIRS</span>
        <h1 class="text-4xl md:text-5xl font-bold tracking-tighter mt-3 mb-6">Vertical Platform Lifts</h1>

        <div class="prose prose-lg text-slate-700">
          <p>
            Our vertical platform lifts cater to the needs of individuals using wheelchairs and power chairs, granting them access to raised porches, decks, and other elevated areas in both residential and commercial settings.
          </p>
          <p>
            Designed for safety and reliability, our lifts are easy to operate and built to withstand the elements. These mobility solutions, resembling small elevators, smoothly transport users vertically.
          </p>
        </div>

        <div class="mt-8 flex gap-4">
          <a href="/contact" class="bg-slate-900 text-white px-7 py-3 rounded-xl font-semibold">Get a Free Quote</a>
          <a href="/service" class="text-sm self-center underline">We also service existing lifts →</a>
        </div>
      </div>

      <div class="lg:col-span-5">
        <Image src={vplImg} alt="Harmar vertical platform lift lifestyle photo" class="rounded-2xl w-full border" width="1024" height="819" loading="lazy" decoding="async" />
      </div>
    </div>
  </div>

  <div class="bg-slate-900 text-white py-12">
    <div class="max-w-5xl mx-auto px-4 grid md:grid-cols-3 gap-8 text-sm">
      <div>
        <div class="uppercase tracking-widest text-xs text-sky-400 mb-2">Ideal for</div>
        <ul class="space-y-1 text-slate-300">
          <li>Front &amp; rear porches</li>
          <li>Decks &amp; patios</li>
          <li>Garage entries</li>
          <li>Small commercial buildings</li>
        </ul>
      </div>
      <div>
        <div class="uppercase tracking-widest text-xs text-sky-400 mb-2">Features</div>
        <ul class="space-y-1 text-slate-300">
          <li>Weather-resistant construction</li>
          <li>Easy-to-use controls</li>
          <li>Non-skid platform surface</li>
          <li>Safety gate &amp; interlocks</li>
        </ul>
      </div>
      <div>
        <div class="uppercase tracking-widest text-xs text-sky-400 mb-2">Next step</div>
        <p class="text-slate-300">Schedule a free site evaluation. We'll assess your space and recommend the right model and lift capacity.</p>
        <a href="/contact" class="mt-3 inline-block text-white underline">Book your consultation →</a>
      </div>
    </div>
  </div>
</Layout>
