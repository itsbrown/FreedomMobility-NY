---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Admin Dashboard | Freedom Mobility NY"
  description="Internal admin dashboard for managing contact submissions."
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-3xl font-bold tracking-tight">Submissions Dashboard</h1>
        <p class="text-slate-600 mt-1">Manage incoming contact requests</p>
      </div>
      <div class="flex items-center gap-3">
        <button id="export-btn" 
                class="px-4 py-2 text-sm font-medium border border-slate-300 hover:bg-slate-50 rounded-lg transition">
          Export CSV
        </button>
        <button id="logout-btn"
                class="px-4 py-2 text-sm font-medium text-red-600 hover:bg-red-50 rounded-lg transition">
          Logout
        </button>
      </div>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      <div class="bg-white border rounded-xl p-4">
        <div class="text-sm text-slate-500">Total Submissions</div>
        <div id="stat-total" class="text-3xl font-semibold mt-1">—</div>
      </div>
      <div class="bg-white border rounded-xl p-4">
        <div class="text-sm text-slate-500">New</div>
        <div id="stat-new" class="text-3xl font-semibold mt-1 text-amber-600">—</div>
      </div>
      <div class="bg-white border rounded-xl p-4">
        <div class="text-sm text-slate-500">Contacted</div>
        <div id="stat-contacted" class="text-3xl font-semibold mt-1 text-blue-600">—</div>
      </div>
      <div class="bg-white border rounded-xl p-4">
        <div class="text-sm text-slate-500">Closed</div>
        <div id="stat-closed" class="text-3xl font-semibold mt-1 text-emerald-600">—</div>
      </div>
    </div>

    <!-- Login Form (shown when not authenticated) -->
    <div id="login-section" class="max-w-md mx-auto">
      <div class="bg-white border rounded-2xl p-8">
        <h2 class="text-xl font-semibold mb-6">Admin Login</h2>
        
        <form id="login-form" class="space-y-4">
          <div>
            <label class="block text-sm font-medium mb-1.5">Email</label>
            <input type="email" id="login-email" required 
                   class="w-full border border-slate-300 focus:border-sky-400 focus:ring-1 focus:ring-sky-400 rounded-lg px-4 py-2.5" 
                   placeholder="admin@freedommobilityny.com" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1.5">Password</label>
            <input type="password" id="login-password" required 
                   class="w-full border border-slate-300 focus:border-sky-400 focus:ring-1 focus:ring-sky-400 rounded-lg px-4 py-2.5" />
          </div>
          <button type="submit" 
                  class="w-full bg-slate-900 hover:bg-black text-white py-3 rounded-xl font-semibold transition">
            Sign In
          </button>
        </form>
        
        <p class="text-xs text-slate-500 mt-4 text-center">
          Contact the site administrator for access.
        </p>
      </div>
    </div>

    <!-- Dashboard (shown when authenticated) -->
    <div id="dashboard-section" class="hidden">
      <!-- Filters -->
      <div class="flex flex-col sm:flex-row gap-4 mb-6">
        <input 
          type="text" 
          id="search-input" 
          placeholder="Search by name, email, or phone..." 
          class="flex-1 border border-slate-300 focus:border-sky-400 focus:ring-1 focus:ring-sky-400 rounded-lg px-4 py-2.5 text-sm"
        />
        
        <select id="status-filter" class="border border-slate-300 focus:border-sky-400 focus:ring-1 focus:ring-sky-400 rounded-lg px-4 py-2.5 text-sm bg-white">
          <option value="">All Statuses</option>
          <option value="new">New</option>
          <option value="contacted">Contacted</option>
          <option value="closed">Closed</option>
        </select>
      </div>

      <!-- Table -->
      <div class="bg-white border rounded-2xl overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead class="bg-slate-50 border-b">
              <tr>
                <th class="text-left px-6 py-3 text-xs font-semibold text-slate-600">Date</th>
                <th class="text-left px-6 py-3 text-xs font-semibold text-slate-600">Name</th>
                <th class="text-left px-6 py-3 text-xs font-semibold text-slate-600">Contact</th>
                <th class="text-left px-6 py-3 text-xs font-semibold text-slate-600">Interest</th>
                <th class="text-left px-6 py-3 text-xs font-semibold text-slate-600">Status</th>
                <th class="text-left px-6 py-3 text-xs font-semibold text-slate-600">Actions</th>
              </tr>
            </thead>
            <tbody id="submissions-table" class="divide-y">
              <!-- Populated by JavaScript -->
            </tbody>
          </table>
        </div>
      </div>

      <p class="text-xs text-slate-500 mt-3 text-center">
        Data is loaded live from your Supabase database.
      </p>
    </div>
  </div>

  <!-- Details Modal -->
  <div id="details-modal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4">
    <div class="bg-white rounded-2xl max-w-2xl w-full max-h-[90vh] overflow-auto">
      <div class="p-6 border-b flex justify-between items-center">
        <h3 class="font-semibold text-lg">Submission Details</h3>
        <button id="close-modal" class="text-slate-400 hover:text-slate-600">✕</button>
      </div>
      
      <div id="modal-content" class="p-6 space-y-6">
        <!-- Populated dynamically -->
      </div>
      
      <div class="p-6 border-t flex gap-3">
        <select id="modal-status" class="border border-slate-300 rounded-lg px-4 py-2 text-sm flex-1">
          <option value="new">New</option>
          <option value="contacted">Contacted</option>
          <option value="closed">Closed</option>
        </select>
        <button id="update-status-btn" 
                class="px-6 py-2 bg-sky-600 hover:bg-sky-700 text-white rounded-lg text-sm font-medium">
          Update Status
        </button>
      </div>
    </div>
  </div>

  <script type="module">
    import { supabase } from '../lib/supabase.js'

    let currentSubmissions = []
    let currentSubmissionId = null

    const loginSection = document.getElementById('login-section')
    const dashboardSection = document.getElementById('dashboard-section')
    const loginForm = document.getElementById('login-form')
    const tableBody = document.getElementById('submissions-table')
    const searchInput = document.getElementById('search-input')
    const statusFilter = document.getElementById('status-filter')
    const modal = document.getElementById('details-modal')

    // Check if user is already logged in
    async function checkAuth() {
      const { data: { session } } = await supabase.auth.getSession()
      
      if (session) {
        showDashboard()
      } else {
        showLogin()
      }
    }

    function showLogin() {
      loginSection.classList.remove('hidden')
      dashboardSection.classList.add('hidden')
    }

    function showDashboard() {
      loginSection.classList.add('hidden')
      dashboardSection.classList.remove('hidden')
      loadSubmissions()
    }

    // Login handler
    loginForm.addEventListener('submit', async (e) => {
      e.preventDefault()
      
      const email = document.getElementById('login-email').value
      const password = document.getElementById('login-password').value
      
      const { error } = await supabase.auth.signInWithPassword({ email, password })
      
      if (error) {
        alert('Login failed: ' + error.message)
        return
      }
      
      showDashboard()
    })

    // Logout
    document.getElementById('logout-btn').addEventListener('click', async () => {
      await supabase.auth.signOut()
      showLogin()
    })

    // Load submissions
    async function loadSubmissions() {
      const { data, error } = await supabase
        .from('submissions')
        .select('*')
        .order('created_at', { ascending: false })

      if (error) {
        console.error(error)
        tableBody.innerHTML = `<tr><td colspan="6" class="px-6 py-8 text-center text-red-600">Failed to load submissions</td></tr>`
        return
      }

      currentSubmissions = data || []
      renderTable(currentSubmissions)
      updateStats(currentSubmissions)
    }

    function updateStats(submissions) {
      document.getElementById('stat-total').textContent = submissions.length
      document.getElementById('stat-new').textContent = submissions.filter(s => s.status === 'new').length
      document.getElementById('stat-contacted').textContent = submissions.filter(s => s.status === 'contacted').length
      document.getElementById('stat-closed').textContent = submissions.filter(s => s.status === 'closed').length
    }

    function renderTable(submissions) {
      if (submissions.length === 0) {
        tableBody.innerHTML = `<tr><td colspan="6" class="px-6 py-8 text-center text-slate-500">No submissions yet.</td></tr>`
        return
      }

      tableBody.innerHTML = submissions.map(sub => {
        const date = new Date(sub.created_at).toLocaleDateString('en-US', { 
          month: 'short', day: 'numeric', year: 'numeric', hour: 'numeric', minute: '2-digit' 
        })
        
        const statusColors = {
          new: 'bg-amber-100 text-amber-700',
          contacted: 'bg-blue-100 text-blue-700',
          closed: 'bg-emerald-100 text-emerald-700'
        }

        return `
          <tr class="hover:bg-slate-50 cursor-pointer" data-id="${sub.id}">
            <td class="px-6 py-4 text-sm text-slate-600">${date}</td>
            <td class="px-6 py-4 font-medium">${sub.name}</td>
            <td class="px-6 py-4">
              <div class="text-sm">${sub.phone}</div>
              <div class="text-xs text-slate-500">${sub.email}</div>
            </td>
            <td class="px-6 py-4 text-sm">${sub.interest || '—'}</td>
            <td class="px-6 py-4">
              <span class="inline-block px-2.5 py-0.5 rounded-full text-xs font-medium ${statusColors[sub.status] || ''}">
                ${sub.status}
              </span>
            </td>
            <td class="px-6 py-4">
              <button class="text-sky-600 hover:text-sky-700 text-sm font-medium view-btn" data-id="${sub.id}">
                View
              </button>
            </td>
          </tr>
        `
      }).join('')

      // Add click handlers
      tableBody.querySelectorAll('tr').forEach(row => {
        row.addEventListener('click', (e) => {
          if (!e.target.classList.contains('view-btn')) {
            const id = row.dataset.id
            showDetails(id)
          }
        })
      })

      tableBody.querySelectorAll('.view-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation()
          showDetails(btn.dataset.id)
        })
      })
    }

    // Filter logic
    function filterSubmissions() {
      const searchTerm = searchInput.value.toLowerCase()
      const status = statusFilter.value

      let filtered = currentSubmissions

      if (searchTerm) {
        filtered = filtered.filter(s => 
          s.name.toLowerCase().includes(searchTerm) ||
          s.email.toLowerCase().includes(searchTerm) ||
          s.phone.includes(searchTerm)
        )
      }

      if (status) {
        filtered = filtered.filter(s => s.status === status)
      }

      renderTable(filtered)
    }

    searchInput.addEventListener('input', filterSubmissions)
    statusFilter.addEventListener('change', filterSubmissions)

    // Show details modal
    function showDetails(id) {
      const sub = currentSubmissions.find(s => s.id === id)
      if (!sub) return

      currentSubmissionId = id

      const date = new Date(sub.created_at).toLocaleString()

      document.getElementById('modal-content').innerHTML = `
        <div class="space-y-4">
          <div class="grid grid-cols-2 gap-4 text-sm">
            <div><span class="text-slate-500">Date:</span> ${date}</div>
            <div><span class="text-slate-500">Status:</span> 
              <span class="font-medium">${sub.status}</span>
            </div>
          </div>
          
          <div>
            <div class="text-xs uppercase tracking-widest text-slate-500 mb-1">Name</div>
            <div class="font-medium text-lg">${sub.name}</div>
          </div>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <div class="text-xs uppercase tracking-widest text-slate-500 mb-1">Phone</div>
              <a href="tel:${sub.phone}" class="text-sky-600 hover:underline">${sub.phone}</a>
            </div>
            <div>
              <div class="text-xs uppercase tracking-widest text-slate-500 mb-1">Email</div>
              <a href="mailto:${sub.email}" class="text-sky-600 hover:underline">${sub.email}</a>
            </div>
          </div>

          ${sub.interest ? `
            <div>
              <div class="text-xs uppercase tracking-widest text-slate-500 mb-1">Interest</div>
              <div>${sub.interest}</div>
            </div>
          ` : ''}

          ${sub.message ? `
            <div>
              <div class="text-xs uppercase tracking-widest text-slate-500 mb-1">Message</div>
              <div class="bg-slate-50 p-4 rounded-lg whitespace-pre-wrap text-sm">${sub.message}</div>
            </div>
          ` : ''}

          ${sub.notes ? `
            <div>
              <div class="text-xs uppercase tracking-widest text-slate-500 mb-1">Internal Notes</div>
              <div class="bg-yellow-50 p-4 rounded-lg whitespace-pre-wrap text-sm">${sub.notes}</div>
            </div>
          ` : ''}
        </div>
      `

      document.getElementById('modal-status').value = sub.status
      modal.classList.remove('hidden')
    }

    // Close modal
    document.getElementById('close-modal').addEventListener('click', () => {
      modal.classList.add('hidden')
    })

    modal.addEventListener('click', (e) => {
      if (e.target === modal) modal.classList.add('hidden')
    })

    // Update status from modal
    document.getElementById('update-status-btn').addEventListener('click', async () => {
      if (!currentSubmissionId) return

      const newStatus = document.getElementById('modal-status').value

      const { error } = await supabase
        .from('submissions')
        .update({ status: newStatus })
        .eq('id', currentSubmissionId)

      if (error) {
        alert('Failed to update status')
        return
      }

      // Refresh data
      await loadSubmissions()
      modal.classList.add('hidden')
      
      // Reopen with updated data
      setTimeout(() => showDetails(currentSubmissionId), 100)
    })

    // Export CSV
    document.getElementById('export-btn').addEventListener('click', () => {
      if (currentSubmissions.length === 0) return

      const headers = ['Date', 'Name', 'Phone', 'Email', 'Interest', 'Message', 'Status', 'Notes']
      const rows = currentSubmissions.map(s => [
        new Date(s.created_at).toISOString(),
        s.name,
        s.phone,
        s.email,
        s.interest || '',
        (s.message || '').replace(/"/g, '""'),
        s.status,
        s.notes || ''
      ])

      let csv = headers.join(',') + '\n'
      rows.forEach(row => {
        csv += row.map(field => `"${field}"`).join(',') + '\n'
      })

      const blob = new Blob([csv], { type: 'text/csv' })
      const url = URL.createObjectURL(blob)
      const a = document.createElement('a')
      a.href = url
      a.download = `submissions-${new Date().toISOString().split('T')[0]}.csv`
      a.click()
      URL.revokeObjectURL(url)
    })

    // Initial load
    checkAuth()
  </script>
</Layout>
